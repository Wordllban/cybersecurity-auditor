# Copy to `.env` (repo root or server/) and fill in. Loaded via Node's native
# --env-file-if-exists; real shell/CI env vars take precedence. `.env` is
# gitignored — never commit secrets.

# Port the API listens on.
PORT=4000

# Path to the SQLite database file. Defaults to ./data/hibit.db when unset.
DATABASE_PATH=./data/hibit.db

# --- OpenRouter (only required for POST /analyze; the app boots without it) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model id used for analysis. Any OpenRouter-supported model.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
